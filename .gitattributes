# ---------------------------------------------------------------------------
# Line-ending normalization
#
# Normalize all text to LF in the repo. This prevents CRLF/LF churn (important
# when editing JS with tools like acorn/eslint and when collaborating across
# Windows/macOS/Linux), and keeps diffs clean.
# ---------------------------------------------------------------------------
* text=auto eol=lf

# Explicit text types
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.hbs   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.svg   text eol=lf

# Binary assets — never touch these
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.eot   binary

# ---------------------------------------------------------------------------
# Vendored libraries — keep them out of GitHub's language statistics and
# collapse them by default in PR diffs. They are still tracked and shipped.
# ---------------------------------------------------------------------------
lib/**            linguist-vendored
lib/**            -diff
